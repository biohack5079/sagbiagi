{
  "hosting": {
    "site": "sagbiagi", 
    "public": "dist",
    "cleanUrls": true,
    "rewrites": [
      {
        "source": "/plower",
        "destination": "/plower.html"
      },
      {
        "source": "/plower/",
        "destination": "/plower/index.html"
      }
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-store, no-cache, must-revalidate, max-age=0"
          }
        ]
      }
    ]
  },
  "emulators": {
    "hosting": {
      "port": 5000
    },
    "ui": {
      "enabled": true,
      "port": 4000
    }
  }
}